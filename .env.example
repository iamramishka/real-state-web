# Production canonical origin — no trailing slash.
# Feeds metadataBase, canonical URL, sitemap.xml, robots.txt, and all JSON-LD URLs.
# Set this in Vercel → Environment Variables (Production, and Preview if desired).
# Public by design (NEXT_PUBLIC_*) — safe to expose. Never put secrets in NEXT_PUBLIC_* vars.
NEXT_PUBLIC_SITE_URL=https://www.nordhaven.example
